.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# husky
.husky/_

# caches & linters
.eslintcache
.stylelintcache
.prettiercache
.cache/

# IDE / Editor
